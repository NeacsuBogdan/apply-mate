<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ApplyMate.App.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <ScrollViewer>
        <StackPanel
            Padding="24"
            Spacing="20">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    FontSize="30"
                    FontWeight="SemiBold"
                    Text="Dashboard" />

                <Button
                    Grid.Column="1"
                    Command="{Binding AddApplicationCommand}"
                    Content="Add Application" />
            </Grid>

            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{Binding ErrorMessage}"
                TextWrapping="WrapWholeWords" />

            <Grid
                ColumnSpacing="12"
                RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Opacity="0.7" Text="Total" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Total}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Opacity="0.7" Text="Applied" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Applied}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Opacity="0.7" Text="In Progress" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding InProgress}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Opacity="0.7" Text="No Response" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding NoResponse}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Opacity="0.7" Text="Rejected" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Rejected}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Opacity="0.7" Text="Accepted" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding Accepted}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Upcoming Interviews" />
                    <ListView
                        Height="320"
                        IsItemClickEnabled="True"
                        ItemClick="OnUpcomingInterviewClick"
                        ItemsSource="{Binding UpcomingInterviews}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding CompanyName}" />
                                    <TextBlock Opacity="0.75" Text="{Binding JobName}" />
                                    <TextBlock Text="{Binding InterviewAt}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Recent Applications" />
                    <ListView
                        Height="320"
                        IsItemClickEnabled="True"
                        ItemClick="OnRecentApplicationClick"
                        ItemsSource="{Binding RecentApplications}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding CompanyName}" />
                                    <TextBlock Opacity="0.75" Text="{Binding JobName}" />
                                    <TextBlock Text="{Binding AppliedOn}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
