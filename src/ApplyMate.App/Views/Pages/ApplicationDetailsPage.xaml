<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ApplyMate.App.Views.Pages.ApplicationDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel
            Padding="24"
            Spacing="14">
            <TextBlock
                FontSize="30"
                FontWeight="SemiBold"
                Text="Application Details" />

            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{Binding ValidationMessage}"
                TextWrapping="WrapWholeWords" />

            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{Binding ErrorMessage}"
                TextWrapping="WrapWholeWords" />

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="Job Name" />
                    <TextBox
                        Text="{Binding JobName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="Company Name" />
                    <TextBox
                        Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <StackPanel Spacing="6">
                <TextBlock Text="Status" />
                <ComboBox
                    DisplayMemberPath="Label"
                    ItemsSource="{Binding StatusOptions}"
                    SelectedItem="{Binding SelectedStatus, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Job Summary" />
                <TextBox
                    AcceptsReturn="True"
                    Height="110"
                    Text="{Binding JobSummary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Job URL" />
                <TextBox
                    Text="{Binding JobUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Applied On" />
                <TextBox
                    IsReadOnly="True"
                    Text="{Binding AppliedOnDisplay}" />
            </StackPanel>

            <ToggleSwitch
                Header="Interview Scheduled"
                IsOn="{Binding HasInterview, Mode=TwoWay}" />

            <Grid
                ColumnSpacing="10"
                Visibility="{Binding InterviewEditorVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="Interview Date" />
                    <DatePicker Date="{Binding InterviewDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="Interview Time" />
                    <TimePicker Time="{Binding InterviewTime, Mode=TwoWay}" />
                </StackPanel>
            </Grid>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="CV" />
                    <TextBlock Text="{Binding CvDisplayName}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Click="OnAttachCvClick"
                            Content="Attach CV" />
                        <Button
                            Command="{Binding OpenCvCommand}"
                            Content="Open CV"
                            IsEnabled="{Binding HasCv}" />
                        <Button
                            Command="{Binding RemoveCvCommand}"
                            Content="Remove CV"
                            IsEnabled="{Binding HasCv}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Spacing="6">
                <TextBlock Text="Notes" />
                <TextBox
                    AcceptsReturn="True"
                    Height="140"
                    Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Command="{Binding SaveCommand}"
                    Content="Save" />
                <Button
                    Command="{Binding DeleteCommand}"
                    Content="Delete" />
                <ProgressRing
                    Height="24"
                    IsActive="{Binding IsBusy}"
                    Width="24" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
