<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ApplyMate.App.Views.Pages.AddApplicationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <ScrollViewer>
        <StackPanel
            Padding="24"
            Spacing="16">
            <TextBlock
                FontSize="30"
                FontWeight="SemiBold"
                Text="Add Application" />

            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{Binding ValidationMessage}"
                TextWrapping="WrapWholeWords" />

            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{Binding ErrorMessage}"
                TextWrapping="WrapWholeWords" />

            <StackPanel Spacing="6">
                <TextBlock Text="Job Name" />
                <TextBox
                    Text="{Binding JobName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g. Software Engineer" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Company Name" />
                <TextBox
                    Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g. Contoso" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Job Summary" />
                <TextBox
                    AcceptsReturn="True"
                    Height="120"
                    Text="{Binding JobSummary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Job URL" />
                <TextBox
                    Text="{Binding JobUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="https://..." />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Applied On" />
                <TextBox
                    IsReadOnly="True"
                    Text="{Binding AppliedOnDisplay}" />
            </StackPanel>

            <StackPanel
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Command="{Binding SaveCommand}"
                    Content="Save" />
                <Button
                    Command="{Binding CancelCommand}"
                    Content="Cancel" />
                <ProgressRing
                    IsActive="{Binding IsBusy}"
                    Width="24"
                    Height="24" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
