<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ApplyMate.App.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded">

    <ScrollViewer>
        <StackPanel
            Padding="24"
            Spacing="14">
            <TextBlock
                FontSize="30"
                FontWeight="SemiBold"
                Text="Settings" />

            <TextBlock
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Text="{Binding ErrorMessage}"
                TextWrapping="WrapWholeWords" />

            <TextBlock
                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                Text="{Binding StatusMessage}"
                TextWrapping="WrapWholeWords" />

            <ToggleSwitch
                Header="Enable Notifications"
                IsOn="{Binding EnableNotifications, Mode=TwoWay}" />

            <StackPanel Spacing="6">
                <TextBlock Text="Daily Notification Time" />
                <TimePicker Time="{Binding DailyNotificationTime, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="No Response Days Threshold" />
                <TextBox
                    InputScope="Number"
                    Text="{Binding NoResponseDaysText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Check Email Stale Days" />
                <TextBox
                    InputScope="Number"
                    Text="{Binding CheckEmailStaleDaysText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <ToggleSwitch
                Header="Run on Startup"
                IsOn="{Binding RunOnStartup, Mode=TwoWay}" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Command="{Binding SaveCommand}"
                    Content="Save Settings" />
                <ProgressRing
                    Height="24"
                    IsActive="{Binding IsBusy}"
                    Width="24" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
